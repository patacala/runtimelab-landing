---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import RealityCheck from '../../components/RealityCheck.astro';
import StructureEmerges from '../../components/StructureEmerges.astro';
import CapabilitiesSnapshot from '../../components/CapabilitiesSnapshot.astro';
import AIConversationDemo from '../../components/AIConversationDemo.astro';
import Control from '../../components/Control.astro';
import Decision from '../../components/Decision.astro';
import WhoWeWorkWith from '../../components/WhoWeWorkWith.astro';
import EngineeringAuthority from '../../components/EngineeringAuthority.astro';
import BookCall from '../../components/BookCall.astro';
import Footer from '../../components/Footer.astro';

import t from '../../i18n/en.json';

const homeSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "SiteNavigationElement",
    "name": [
      "Web Development",
      "AI Agents",
      "Automations",
      "Custom Software",
      "Blog",
      "Book a call"
    ],
    "url": [
      "https://runtime-lab.com/en/services/web-development",
      "https://runtime-lab.com/en/services/ai-agents",
      "https://runtime-lab.com/en/services/automations",
      "https://runtime-lab.com/en/services/custom-software",
      "https://runtime-lab.com/en/blog",
      "https://runtime-lab.com/en/#contact"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "url": "https://runtime-lab.com/en",
    "name": "RuntimeLab",
    "description": "Websites and web design in Miami; web development, AI agents, automations and custom software",
    "inLanguage": "en",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://runtime-lab.com/en/blog?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "RuntimeLab Services",
    "description": "Web development, AI agents, automations, and custom software services",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "Service",
          "name": "Web Development",
          "description": "Professional websites focused on conversion, speed, and SEO. Your site captures leads and feeds your stack.",
          "url": "https://runtime-lab.com/en/services/web-development",
          "provider": { "@id": "https://runtime-lab.com/#organization" },
          "areaServed": [
            { "@type": "City", "name": "Miami", "containedInPlace": { "@type": "State", "name": "Florida", "containedInPlace": { "@type": "Country", "name": "United States" } } }
          ]
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@type": "Service",
          "name": "AI Agents",
          "description": "We build AI agents that respond, qualify leads, and book appointments automatically, available 24/7 from any channel.",
          "url": "https://runtime-lab.com/en/services/ai-agents",
          "provider": { "@id": "https://runtime-lab.com/#organization" }
        }
      },
      {
        "@type": "ListItem",
        "position": 3,
        "item": {
          "@type": "Service",
          "name": "Business Automations",
          "description": "We build intelligent workflows with n8n that connect your tools, eliminate manual tasks, and scale your operation automatically.",
          "url": "https://runtime-lab.com/en/services/automations",
          "provider": { "@id": "https://runtime-lab.com/#organization" }
        }
      },
      {
        "@type": "ListItem",
        "position": 4,
        "item": {
          "@type": "Service",
          "name": "Custom Software Development",
          "description": "We develop platforms, dashboards, and custom systems with scalable architecture for businesses that need more than generic tools.",
          "url": "https://runtime-lab.com/en/services/custom-software",
          "provider": { "@id": "https://runtime-lab.com/#organization" }
        }
      },
      {
        "@type": "ListItem",
        "position": 5,
        "item": {
          "@type": "Service",
          "name": "Omnichannel CRM",
          "description": "We centralize all your WhatsApp, email, web, and social conversations in a single inbox with pipeline management and integrated AI.",
          "url": "https://runtime-lab.com/en/#capabilities",
          "provider": { "@id": "https://runtime-lab.com/#organization" }
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": "https://runtime-lab.com/en/#service-websites-miami",
    "name": "Websites and web design in Miami",
    "serviceType": "Web design and website development",
    "description": "Professional websites for Miami and Florida businesses: conversion-focused design, SEO, speed, and integrations with AI agents and CRM.",
    "url": "https://runtime-lab.com/en/services/web-development",
    "provider": { "@id": "https://runtime-lab.com/#organization" },
    "areaServed": [
      { "@type": "City", "name": "Miami", "containedInPlace": { "@type": "State", "name": "Florida" } },
      { "@type": "AdministrativeArea", "name": "Florida" },
      { "@type": "Country", "name": "United States" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Do you build websites for businesses in Miami?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. RuntimeLab is based in Miami, Florida. We design and build professional websites for local businesses with a focus on conversion and SEO, connected to AI agents, automations, and CRM. We also work with clients across the United States and remotely worldwide."
        }
      },
      {
        "@type": "Question",
        "name": "What is an AI agent and how can it help my business?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "An AI agent is an automated system that responds to messages, qualifies leads, and books appointments on your behalf, available 24/7 on WhatsApp, email, and web. It allows your business to serve clients automatically without manual intervention."
        }
      },
      {
        "@type": "Question",
        "name": "How long does it take to build a professional website?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Building a professional website takes 2 to 4 weeks depending on complexity. This includes conversion-focused design, form integration, SEO optimization, and connection to your AI and CRM systems."
        }
      },
      {
        "@type": "Question",
        "name": "What are business automations?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Business automations are workflows that connect your tools (CRM, email, WhatsApp, calendars) to execute tasks automatically: send follow-ups, qualify leads, book appointments, and notify your team without manual work."
        }
      },
      {
        "@type": "Question",
        "name": "What does custom software development include?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Custom software development includes internal platforms, client portals, management dashboards, and API integrations with existing systems. We build with scalable architecture so your operation grows without technical limitations."
        }
      },
      {
        "@type": "Question",
        "name": "Can all your services be integrated together?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. We design all services (web, AI, automations, and CRM) to work as one unified system: the visitor lands on your site, the AI agent responds, the CRM centralizes the conversation, and automations handle automatic follow-up."
        }
      }
    ]
  }
];
---

<BaseLayout
  lang="en"
  title="RuntimeLab — Websites & Web Design in Miami | AI, Automation & CRM"
  description="Web design and websites with a Miami base: conversion-focused sites with AI, automations, and omnichannel CRM. We work remotely with teams anywhere."
  keywords="Miami web design, Miami websites, web development Miami, business website Miami, web development, AI agents, artificial intelligence agents, automations, custom software development, omnichannel CRM, RuntimeLab"
  schemas={homeSchemas}
  hreflangEs="https://runtime-lab.com/"
  hreflangEn="https://runtime-lab.com/en/"
>
  <Nav t={t.nav} lang="en" />

  <main id="main-content">
    <Hero t={t.hero} />
    <RealityCheck t={t.realityCheck} />
    <StructureEmerges t={t.structure} />
    <CapabilitiesSnapshot t={t.capabilities} />
    <AIConversationDemo t={t.aiDemo} />
    <Control t={t.control} />
    <Decision t={t.decision} />
    <WhoWeWorkWith t={t.whoWeWorkWith} />
    <EngineeringAuthority t={t.engineering} />
    <BookCall t={t.bookCall} />
  </main>

  <Footer t={t.footer} nav={{ logo: t.nav.logo }} lang="en" />
</BaseLayout>
