---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import RealityCheck from '../components/RealityCheck.astro';
import StructureEmerges from '../components/StructureEmerges.astro';
import CapabilitiesSnapshot from '../components/CapabilitiesSnapshot.astro';
import AIConversationDemo from '../components/AIConversationDemo.astro';
import Control from '../components/Control.astro';
import Decision from '../components/Decision.astro';
import WhoWeWorkWith from '../components/WhoWeWorkWith.astro';
import EngineeringAuthority from '../components/EngineeringAuthority.astro';
import BookCall from '../components/BookCall.astro';
import Footer from '../components/Footer.astro';

import t from '../i18n/es.json';

const homeSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "SiteNavigationElement",
    "name": [
      "Páginas Web",
      "Agentes IA",
      "Automatizaciones",
      "Software a Medida",
      "Blog",
      "Agendar llamada"
    ],
    "url": [
      "https://runtime-lab.com/servicios/desarrollo-web",
      "https://runtime-lab.com/servicios/agentes-ia",
      "https://runtime-lab.com/servicios/automatizaciones",
      "https://runtime-lab.com/servicios/software-a-medida",
      "https://runtime-lab.com/blog",
      "https://runtime-lab.com/#contact"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "url": "https://runtime-lab.com",
    "name": "RuntimeLab",
    "description": "Páginas web y diseño web en Miami; desarrollo web, agentes de IA, automatizaciones y software a medida",
    "inLanguage": "es",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://runtime-lab.com/blog?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Servicios de RuntimeLab",
    "description": "Servicios de desarrollo web, agentes de IA, automatizaciones y software a medida",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "Service",
          "name": "Desarrollo de Páginas Web",
          "description": "Diseñamos páginas web profesionales en Miami y remotas para LATAM: conversión, velocidad y SEO. Tu sitio captura leads y los envía a tu sistema.",
          "url": "https://runtime-lab.com/servicios/desarrollo-web",
          "provider": { "@id": "https://runtime-lab.com/#organization" },
          "areaServed": [
            { "@type": "City", "name": "Miami", "containedInPlace": { "@type": "State", "name": "Florida", "containedInPlace": { "@type": "Country", "name": "United States" } } }
          ]
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@type": "Service",
          "name": "Agentes de Inteligencia Artificial",
          "description": "Creamos agentes de IA que responden, califican leads y agendan citas automáticamente, disponibles 24/7 desde cualquier canal.",
          "url": "https://runtime-lab.com/servicios/agentes-ia",
          "provider": { "@id": "https://runtime-lab.com/#organization" }
        }
      },
      {
        "@type": "ListItem",
        "position": 3,
        "item": {
          "@type": "Service",
          "name": "Automatizaciones de Negocio",
          "description": "Construimos workflows inteligentes con n8n que conectan tus herramientas, eliminan tareas manuales y escalan tu operación automáticamente.",
          "url": "https://runtime-lab.com/servicios/automatizaciones",
          "provider": { "@id": "https://runtime-lab.com/#organization" }
        }
      },
      {
        "@type": "ListItem",
        "position": 4,
        "item": {
          "@type": "Service",
          "name": "Software a Medida",
          "description": "Desarrollamos plataformas, dashboards y sistemas personalizados con arquitectura escalable para empresas que necesitan más que herramientas genéricas.",
          "url": "https://runtime-lab.com/servicios/software-a-medida",
          "provider": { "@id": "https://runtime-lab.com/#organization" }
        }
      },
      {
        "@type": "ListItem",
        "position": 5,
        "item": {
          "@type": "Service",
          "name": "CRM Omnichannel",
          "description": "Centralizamos todas tus conversaciones de WhatsApp, email, web y redes en una sola bandeja, con gestión de pipeline y IA integrada.",
          "url": "https://runtime-lab.com/#capabilities",
          "provider": { "@id": "https://runtime-lab.com/#organization" }
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": "https://runtime-lab.com/#service-paginas-web-miami",
    "name": "Páginas web y diseño web en Miami",
    "serviceType": "Diseño y desarrollo de sitios web",
    "description": "Páginas web profesionales para negocios en Miami y Florida: enfoque en conversión, SEO, velocidad e integración con IA y CRM.",
    "url": "https://runtime-lab.com/servicios/desarrollo-web",
    "provider": { "@id": "https://runtime-lab.com/#organization" },
    "areaServed": [
      { "@type": "City", "name": "Miami", "containedInPlace": { "@type": "State", "name": "Florida" } },
      { "@type": "AdministrativeArea", "name": "Florida" },
      { "@type": "Place", "name": "LATAM" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Hacen páginas web para negocios en Miami?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí. RuntimeLab tiene sede en Miami, Florida. Diseñamos y desarrollamos páginas web profesionales para empresas locales, con foco en conversión y SEO, y las conectamos con agentes de IA, automatizaciones y CRM. También trabajamos con clientes en el resto de EE. UU. y LATAM de forma remota."
        }
      },
      {
        "@type": "Question",
        "name": "¿Qué es un agente de IA y cómo puede ayudar a mi negocio?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Un agente de IA es un sistema automatizado que responde mensajes, califica leads y agenda citas por ti, disponible 24/7 en WhatsApp, email y web. Permite que tu negocio atienda clientes automáticamente sin intervención manual."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuánto tarda en implementarse una página web profesional?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "El desarrollo de una página web profesional tarda entre 2 y 4 semanas, dependiendo de la complejidad. Incluye diseño orientado a conversión, integración con formularios, optimización SEO y conexión con tus sistemas de IA y CRM."
        }
      },
      {
        "@type": "Question",
        "name": "¿Qué son las automatizaciones de negocio?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Las automatizaciones de negocio son workflows que conectan tus herramientas (CRM, email, WhatsApp, calendarios) para ejecutar tareas automáticamente: enviar seguimientos, calificar leads, agendar citas y notificar a tu equipo sin trabajo manual."
        }
      },
      {
        "@type": "Question",
        "name": "¿Qué incluye el software a medida?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "El software a medida incluye plataformas internas, portales de clientes, dashboards de gestión e integraciones con APIs existentes. Lo construimos con arquitectura escalable para que tu operación crezca sin limitaciones técnicas."
        }
      },
      {
        "@type": "Question",
        "name": "¿Pueden integrar todos los servicios entre sí?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí. Diseñamos todos los servicios (web, IA, automatizaciones y CRM) para que trabajen como un sistema único: el visitante llega a tu web, el agente de IA responde, el CRM centraliza la conversación y las automatizaciones dan seguimiento automático."
        }
      }
    ]
  }
];
---

<BaseLayout
  lang="es"
  title="RuntimeLab — Páginas web en Miami | Diseño web, IA y sistemas que generan clientes"
  description="Páginas web y diseño web en Miami para negocios que quieren más clientes: sitios que convierten, con IA, automatización y CRM. También LATAM y proyectos remotos."
  keywords="páginas web Miami, diseño web Miami, crear página web Miami, agencia páginas web Miami, desarrollo web Miami, sitio web empresa Miami, páginas web Florida, desarrollo web, agentes de inteligencia artificial, automatizaciones, software a medida, CRM omnichannel, RuntimeLab"
  schemas={homeSchemas}
>
  <Nav t={t.nav} lang="es" />

  <main id="main-content">
    <Hero t={t.hero} conversionHero />
    <RealityCheck t={t.realityCheck} />
    <StructureEmerges t={t.structure} />
    <CapabilitiesSnapshot t={t.capabilities} />
    <AIConversationDemo t={t.aiDemo} />
    <Control t={t.control} />
    <Decision t={t.decision} />
    <WhoWeWorkWith t={t.whoWeWorkWith} />
    <EngineeringAuthority t={t.engineering} />
    <BookCall t={t.bookCall} />
  </main>

  <Footer t={t.footer} nav={{ logo: t.nav.logo }} lang="es" />
</BaseLayout>
