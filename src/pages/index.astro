---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import RealityCheck from '../components/RealityCheck.astro';
import StructureEmerges from '../components/StructureEmerges.astro';
import CapabilitiesSnapshot from '../components/CapabilitiesSnapshot.astro';
import AIConversationDemo from '../components/AIConversationDemo.astro';
import Control from '../components/Control.astro';
import Decision from '../components/Decision.astro';
import WhoWeWorkWith from '../components/WhoWeWorkWith.astro';
import EngineeringAuthority from '../components/EngineeringAuthority.astro';
import BookCall from '../components/BookCall.astro';
import Footer from '../components/Footer.astro';

import t from '../i18n/es.json';
---

<BaseLayout
  lang="es"
  title="RuntimeLab — Web, Agentes IA, Automatización y CRM"
  description="Construimos sistemas inteligentes que conectan tu web, agentes de IA, automatizaciones y CRM omnichannel para captar, atender y convertir clientes automáticamente."
>
  <Nav t={t.nav} lang="es" />

  <main id="main-content">
    <Hero t={t.hero} />
    <RealityCheck t={t.realityCheck} />
    <StructureEmerges t={t.structure} />
    <CapabilitiesSnapshot t={t.capabilities} />
    <AIConversationDemo t={t.aiDemo} />
    <Control t={t.control} />
    <Decision t={t.decision} />
    <WhoWeWorkWith t={t.whoWeWorkWith} />
    <EngineeringAuthority t={t.engineering} />
    <BookCall t={t.bookCall} />
  </main>

  <Footer t={t.footer} nav={{ logo: t.nav.logo }} lang="es" />
</BaseLayout>
