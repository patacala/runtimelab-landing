---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import t from '../i18n/en.json';
---

<BaseLayout
  lang="en"
  title="Privacy Policy — Runtime Lab"
  description="Runtime Lab's Privacy Policy: how we collect, use, and protect your personal information."
>
  <Nav t={t.nav} lang="en" />

  <main id="main-content" class="privacy-main">
    <div class="privacy-container">

      <div class="privacy-header reveal">
        <div class="privacy-badge">LEGAL</div>
        <h1 class="privacy-title">Privacy Policy</h1>
        <p class="privacy-meta">Last updated: March 2026</p>
      </div>

      <div class="privacy-intro reveal">
        <p>Runtime Lab ("we", "our", or "us") respects your privacy and is committed to protecting the personal information you share with us when visiting our website <a href="https://runtime-lab.com" class="privacy-link">https://runtime-lab.com</a>.</p>
        <p>This Privacy Policy explains what information we collect, how we use it, and the rights you have regarding your data.</p>
      </div>

      <div class="privacy-body">

        <section class="privacy-section reveal">
          <h2 class="privacy-section-title"><span class="privacy-num">01</span> Information We Collect</h2>
          <p>We collect only limited personal information that you voluntarily provide through forms or interactions on our website.</p>
          <p>The information we may collect includes:</p>
          <ul class="privacy-list">
            <li>Name</li>
            <li>Email address</li>
          </ul>
          <p>We do not collect sensitive personal information such as financial details, government identification numbers, or payment information through our website.</p>
        </section>

        <section class="privacy-section reveal">
          <h2 class="privacy-section-title"><span class="privacy-num">02</span> How We Use Your Information</h2>
          <p>We use the information you provide to:</p>
          <ul class="privacy-list">
            <li>Respond to inquiries or messages you send through our website</li>
            <li>Communicate about potential services or collaborations</li>
            <li>Improve our services and website experience</li>
            <li>Send occasional updates related to Runtime Lab services (only if you opt in)</li>
          </ul>
          <p>We do not sell, rent, or trade your personal information.</p>
        </section>

        <section class="privacy-section reveal">
          <h2 class="privacy-section-title"><span class="privacy-num">03</span> AI Interaction and Automated Systems</h2>
          <p>Our website may include automated assistants or AI-powered chat systems designed to answer questions or assist visitors.</p>
          <p>When interacting with these systems:</p>
          <ul class="privacy-list">
            <li>Messages you send may be processed by automated systems.</li>
            <li>Conversations may be temporarily stored to improve system performance.</li>
            <li>You should avoid sharing sensitive personal or confidential business information in chat.</li>
          </ul>
          <p>AI responses are provided for informational purposes and may not always be accurate.</p>
        </section>

        <section class="privacy-section reveal">
          <h2 class="privacy-section-title"><span class="privacy-num">04</span> Data Storage and Security</h2>
          <p>We take reasonable steps to protect your information using modern security practices.</p>
          <p>However, no internet transmission or storage system can be guaranteed to be 100% secure.</p>
          <p>We retain personal data only as long as necessary to respond to your inquiry or maintain our business relationship.</p>
        </section>

        <section class="privacy-section reveal">
          <h2 class="privacy-section-title"><span class="privacy-num">05</span> Third-Party Services</h2>
          <p>Our website may use third-party services to support functionality such as:</p>
          <ul class="privacy-list">
            <li>Hosting infrastructure</li>
            <li>Analytics tools</li>
            <li>Email communication services</li>
            <li>AI processing services</li>
          </ul>
          <p>These providers may process limited data strictly for operational purposes.</p>
        </section>

        <section class="privacy-section reveal">
          <h2 class="privacy-section-title"><span class="privacy-num">06</span> Cookies and Analytics</h2>
          <p>Our website may use basic cookies or analytics tools to understand how visitors interact with the site.</p>
          <p>This information may include:</p>
          <ul class="privacy-list">
            <li>Browser type</li>
            <li>Device type</li>
            <li>Pages visited</li>
            <li>Approximate location (non-precise)</li>
          </ul>
          <p>This data is used only to improve website performance.</p>
        </section>

        <section class="privacy-section reveal">
          <h2 class="privacy-section-title"><span class="privacy-num">07</span> Your Rights</h2>
          <p>Depending on your jurisdiction, you may have the right to:</p>
          <ul class="privacy-list">
            <li>Request access to your personal data</li>
            <li>Request correction of inaccurate information</li>
            <li>Request deletion of your data</li>
          </ul>
          <p>To make a request, contact us at: <a href="mailto:support@runtime-lab.com" class="privacy-link">support@runtime-lab.com</a></p>
        </section>

        <section class="privacy-section reveal">
          <h2 class="privacy-section-title"><span class="privacy-num">08</span> Children's Privacy</h2>
          <p>Our services are not directed toward individuals under the age of 13.</p>
          <p>We do not knowingly collect personal information from children.</p>
        </section>

        <section class="privacy-section reveal">
          <h2 class="privacy-section-title"><span class="privacy-num">09</span> Changes to This Policy</h2>
          <p>We may update this Privacy Policy from time to time.</p>
          <p>Updates will be posted on this page with a revised "Last updated" date.</p>
        </section>

        <section class="privacy-section reveal">
          <h2 class="privacy-section-title"><span class="privacy-num">10</span> Contact Information</h2>
          <p>If you have questions about this Privacy Policy, you may contact us at:</p>
          <div class="privacy-contact-card">
            <p class="privacy-contact-name">Runtime Lab</p>
            <p>2125 Biscayne Blvd, Ste 204 #24417<br />Miami, Florida 33137<br />United States</p>
            <p>
              Email: <a href="mailto:support@runtime-lab.com" class="privacy-link">support@runtime-lab.com</a><br />
              Phone: <a href="tel:+16452205559" class="privacy-link">+1 645 220 5559</a>
            </p>
          </div>
        </section>

      </div>
    </div>
  </main>

  <Footer t={t.footer} nav={{ logo: t.nav.logo }} lang="en" />
</BaseLayout>

<style>
  .privacy-main {
    background-color: #0B0F14;
    min-height: 100vh;
    padding-top: 96px;
    padding-bottom: 0;
  }

  .privacy-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
  }

  /* Header */
  .privacy-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #1E293B;
  }

  .privacy-badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: #2563EB;
    background: rgba(37, 99, 235, 0.08);
    border: 1px solid rgba(37, 99, 235, 0.18);
    border-radius: 4px;
    padding: 3px 10px;
    margin-bottom: 1.25rem;
  }

  .privacy-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: #F8FAFC;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
    line-height: 1.1;
  }

  .privacy-meta {
    font-size: 0.8125rem;
    color: #64748B;
    margin: 0;
  }

  /* Intro */
  .privacy-intro {
    margin-bottom: 3rem;
  }

  .privacy-intro p {
    font-size: 1rem;
    color: #94A3B8;
    line-height: 1.75;
    margin: 0 0 1rem;
  }

  .privacy-intro p:last-child { margin-bottom: 0; }

  /* Sections */
  .privacy-section {
    margin-bottom: 2.75rem;
    padding-bottom: 2.75rem;
    border-bottom: 1px solid rgba(30, 41, 59, 0.6);
  }

  .privacy-section:last-child {
    border-bottom: none;
    margin-bottom: 0;
  }

  .privacy-section-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.0625rem;
    font-weight: 700;
    color: #F8FAFC;
    letter-spacing: -0.01em;
    margin: 0 0 1.25rem;
  }

  .privacy-num {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #2563EB;
    background: rgba(37, 99, 235, 0.08);
    border: 1px solid rgba(37, 99, 235, 0.15);
    border-radius: 4px;
    padding: 2px 7px;
    flex-shrink: 0;
  }

  .privacy-section p {
    font-size: 0.9375rem;
    color: #94A3B8;
    line-height: 1.75;
    margin: 0 0 0.875rem;
  }

  .privacy-section p:last-child { margin-bottom: 0; }

  /* Lists */
  .privacy-list {
    list-style: none;
    padding: 0;
    margin: 0 0 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .privacy-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.9375rem;
    color: #94A3B8;
    line-height: 1.6;
    padding-left: 0.25rem;
  }

  .privacy-list li::before {
    content: '';
    display: block;
    width: 5px;
    height: 5px;
    background: #2563EB;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.55em;
  }

  /* Links */
  .privacy-link {
    color: #3B82F6;
    text-decoration: none;
    transition: color 0.15s;
  }
  .privacy-link:hover { color: #60A5FA; text-decoration: underline; }

  /* Contact card */
  .privacy-contact-card {
    background: #10151C;
    border: 1px solid #1E293B;
    border-radius: 10px;
    padding: 1.5rem;
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .privacy-contact-card p {
    font-size: 0.9375rem !important;
    color: #94A3B8 !important;
    line-height: 1.75 !important;
    margin: 0 !important;
  }

  .privacy-contact-name {
    font-weight: 600 !important;
    color: #F8FAFC !important;
  }

  /* Reveal */
  .reveal {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .reveal.is-visible {
    opacity: 1;
    transform: none;
  }
</style>
