      "@type": "Service",
      "name": "Software a Medida para Empresas",
      "description": "Desarrollo de software personalizado: plataformas internas, portales, dashboards y sistemas integrados con arquitectura escalable.",
      "provider": { "@id": "https://runtime-lab.com/#organization" },
      "areaServed": { "@type": "Country", "name": "Mexico" },
      "serviceType": "Custom Software Development",
      "url": "https://runtime-lab.com/servicios/software-a-medida"
    },
    {
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "Cómo desarrollamos software a medida",
      "description": "Proceso ágil de 5 etapas para construir software personalizado",
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Descubrimiento y definición", "text": "Mapeamos procesos y definimos alcance, arquitectura y stack tecnológico." },
        { "@type": "HowToStep", "position": 2, "name": "Diseño de producto", "text": "Wireframes, prototipos y diseño de interfaz validados antes del desarrollo." },
        { "@type": "HowToStep", "position": 3, "name": "Desarrollo por sprints", "text": "Ciclos de 2 semanas con entregas funcionales y feedback continuo." },
        { "@type": "HowToStep", "position": 4, "name": "QA y pruebas", "text": "Pruebas unitarias, de integración, rendimiento y seguridad." },
        { "@type": "HowToStep", "position": 5, "name": "Despliegue y soporte", "text": "Despliegue en producción, CI/CD, documentación y soporte post-lanzamiento." }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://runtime-lab.com/" },
        { "@type": "ListItem", "position": 2, "name": "Servicios", "item": "https://runtime-lab.com/#capabilities" },
        { "@type": "ListItem", "position": 3, "name": "Software a Medida", "item": "https://runtime-lab.com/servicios/software-a-medida" }
      ]
    }
  ],
};
