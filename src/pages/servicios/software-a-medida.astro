  ],
  process: {
    title: 'Cómo desarrollamos tu software a medida',
    sub: 'Un proceso de desarrollo ágil, transparente y con entregas frecuentes.',
    steps: [
      {
        num: '01',
        title: 'Descubrimiento y definición',
        desc: 'Mapeamos tus procesos actuales, identificamos los problemas que el software debe resolver y definimos el alcance, arquitectura y stack tecnológico.',
      },
      {
        num: '02',
        title: 'Diseño de producto',
        desc: 'Creamos wireframes, prototipos interactivos y el diseño de la interfaz. Validamos con tu equipo antes de comenzar el desarrollo.',
      },
      {
        num: '03',
        title: 'Desarrollo por sprints',
        desc: 'Desarrollamos en ciclos de 2 semanas con entregas funcionales. Revisas y das feedback en cada sprint antes de continuar al siguiente.',
      },
      {
        num: '04',
        title: 'QA y pruebas',
        desc: 'Pruebas unitarias, de integración y con usuarios reales. Verificamos rendimiento, seguridad y compatibilidad en todos los escenarios.',
      },
      {
        num: '05',
        title: 'Despliegue y soporte',
        desc: 'Desplegamos en tu infraestructura o en la nube, configuramos CI/CD, documentamos el sistema y ofrecemos soporte técnico post-lanzamiento.',
      },
    ],
  },
  useCases: {
    title: '¿Qué tipo de software desarrollamos?',
    items: [
      {
        label: 'Plataformas internas de gestión',
        desc: 'Sistemas para gestionar operaciones, equipos, inventario, producción o cualquier proceso interno que hoy haces en hojas de cálculo.',
      },
      {
        label: 'Portales de clientes',
        desc: 'Espacios donde tus clientes pueden ver el estado de sus proyectos, facturas, documentos o acceder a servicios de forma autónoma.',
      },
      {
        label: 'Dashboards y analytics',
        desc: 'Visualización en tiempo real de tus KPIs de ventas, operaciones, finanzas o cualquier área, con datos de múltiples fuentes unificados.',
