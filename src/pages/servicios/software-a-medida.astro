    {
      icon: 'code' as const,
      title: 'Construido para tu proceso exacto',
      desc: 'No adaptas tu negocio al software, el software se adapta a tu negocio. Cada flujo, regla y vista diseñada para cómo opera tu equipo.',
    },
    {
      icon: 'zap' as const,
      title: 'Integración con sistemas existentes',
      desc: 'Conectamos con tus APIs, bases de datos, herramientas de pago, ERP y cualquier sistema que ya uses, sin fricciones ni silos de datos.',
    },
    {
      icon: 'shield' as const,
      title: 'Arquitectura escalable',
      desc: 'Construimos con las mismas prácticas que usamos en plataformas enterprise: código limpio, tests, CI/CD y diseño que escala sin reescribir.',
