      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://runtime-lab.com/' },
        { '@type': 'ListItem', position: 2, name: 'Servicios', item: 'https://runtime-lab.com/#capabilities' },
        { '@type': 'ListItem', position: 3, name: 'Software a medida', item: 'https://runtime-lab.com/servicios/software-a-medida' },
