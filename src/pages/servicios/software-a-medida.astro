---
import ServicePage from '../../components/ServicePage.astro';
import nav from '../../i18n/es.json';

const data = {
  lang: 'es' as const,
  meta: {
    title: 'Software a Medida para Empresas | Desarrollo de Software | RuntimeLab',
    description: 'Desarrollamos software a medida: plataformas internas, portales, dashboards y sistemas personalizados con arquitectura escalable. Cuando las herramientas genéricas no son suficientes.',
    keywords: 'software a medida, desarrollo de software, software personalizado, plataforma a medida, dashboard empresarial, portal web, software empresarial, aplicaciones a medida',
    hreflangEs: 'https://runtime-lab.com/servicios/software-a-medida',
    hreflangEn: 'https://runtime-lab.com/en/services/custom-software',
  },
  nav: nav.nav,
  footer: nav.footer,
  hero: {
    badge: 'SOFTWARE A MEDIDA',
    title: 'Software a medida construido para escalar con tu operación',
    sub: 'Cuando las herramientas genéricas se quedan cortas, construimos exactamente lo que tu negocio necesita: plataformas internas, portales de clientes, dashboards de gestión y sistemas integrados con tu infraestructura existente.',
    cta: 'Agendar llamada gratuita',
    ctaHref: '/#decision',
  },
  benefitsTitle: '¿Por qué software a medida en lugar de herramientas genéricas?',
