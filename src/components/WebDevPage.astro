<style>
/* ══ PROCESS — Sticky stack ══ */
.wd-process-section {
  padding: 0 0 160px;
  background: #0B0F14;
}
.wd-process-section .wd-section-header {
  padding: 100px 0 72px;
}
@media (max-width: 640px) {
  .wd-process-section .wd-section-header { padding: 72px 0 40px; }
  .wd-process-section { padding-bottom: 80px; }
}

/* Wrapper: full-width with small lateral padding only.
   gap: 60vh creates a scroll "breathing zone" between cards —
   so each card is the sole focus for a full screen before
   the next slides up from below. */
.wd-stack-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 60vh;
  width: 100%;
  padding: 0 40px;
  box-sizing: border-box;
}

/* Cards: sticky so each new card slides over the previous.
   Fixed width (min(1120px, 100%)) ensures all cards are the
   same size regardless of content length.
   top is set so the card rests vertically centered when sticky. */
.wd-stack-card {
  position: sticky;
  /* Center the card vertically: (viewport - card height) / 2 */
  top: calc((100vh - clamp(480px, 68vh, 680px)) / 2);
  z-index: var(--card-z);
  width: min(75%, 100%);
  min-height: clamp(480px, 68vh, 680px);
  border-radius: 24px;
  overflow: hidden;
  box-shadow:
    0 8px 32px rgba(0,0,0,0.28),
    0 24px 64px rgba(0,0,0,0.22);
  /* Short transform transition so stack tracks scroll; long shadow for polish */
  transition: transform 0.1s linear,
              box-shadow 0.4s ease;
  will-change: transform;
}

/* JS sets inline transform per burial depth (progressive staircase).
   .is-buried is kept for box-shadow and any CSS-only fallbacks. */
.wd-stack-card.is-buried {
  box-shadow:
    0 2px 12px rgba(0,0,0,0.18),
    0 6px 20px rgba(0,0,0,0.14);
}

@media (max-width: 900px) {
  .wd-stack-wrapper {
    padding: 0 20px;
    gap: 40vh;
  }
  /* Slightly smaller max-width on tablet */
  .wd-stack-card {
    width: min(860px, 100%);
  }
}
@media (max-width: 640px) {
  .wd-stack-card {
    position: relative;
    top: auto;
    width: 100%;
    border-radius: 18px;
    min-height: auto;
  }
  .wd-stack-wrapper {
    padding: 0 14px;
    gap: 16px;
  }
  /* On mobile JS clears inline transforms, nothing needed here */
}

/* Card themes */
.wd-card-light  { background: #FFFFFF; }
.wd-card-blue   { background: #1D4ED8; }
.wd-card-purple { background: #6D28D9; }
.wd-card-dark   { background: #0D1117; }
.wd-card-sky    { background: #EFF6FF; }
.wd-card-indigo { background: #312E81; }

/* Inner layout */
.wd-stack-inner {
  display: grid;
  grid-template-columns: 52fr 48fr;
  height: 100%;
  min-height: clamp(520px, 68vh, 700px);
}
@media (max-width: 900px) {
  .wd-stack-inner { grid-template-columns: 1fr; min-height: auto; }
}

/* Visual side */
.wd-stack-visual {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 56px 40px 56px 64px;
  position: relative;
  overflow: hidden;
}
@media (max-width: 900px) {
  .wd-stack-visual { padding: 44px 28px 24px; }
}

/* Content side */
.wd-stack-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 72px 64px 72px 48px;
}
@media (max-width: 900px) {
  .wd-stack-content { padding: 24px 28px 52px; }
}

.wd-stack-num {
  display: block;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.1em;
  margin-bottom: 20px;
}
.wd-num-light  { color: #2563EB; }
.wd-num-blue   { color: rgba(255,255,255,0.55); }
.wd-num-purple { color: rgba(255,255,255,0.6); }
.wd-num-dark   { color: #60A5FA; }
.wd-num-sky    { color: #1D4ED8; }
.wd-num-indigo { color: rgba(255,255,255,0.55); }

.wd-stack-title {
  font-size: clamp(2.25rem, 3.8vw, 3.25rem);
  font-weight: 800;
  letter-spacing: -0.04em;
  line-height: 1.1;
  margin-bottom: 24px;
}
.wd-title-dark  { color: #0F172A; }
.wd-title-light { color: #FFFFFF; }

.wd-stack-desc {
