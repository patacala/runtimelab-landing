  line-height: 1.75;
  margin-bottom: 32px;
  max-width: 38ch;
}
.wd-desc-dark  { color: #4B5563; }
.wd-desc-light { color: rgba(255,255,255,0.72); }

.wd-stack-outcome {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  font-weight: 600;
  border-radius: 8px;
  padding: 8px 14px;
  width: fit-content;
}
.wd-outcome-dark {
  color: #1E40AF;
  background: rgba(37,99,235,0.08);
  border: 1px solid rgba(37,99,235,0.2);
}
.wd-outcome-light {
  color: rgba(255,255,255,0.9);
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.2);
}

/* ── Simulation: Brief (card light) ── */
.wd-sim-window {
  width: 100%;
  max-width: 440px;
