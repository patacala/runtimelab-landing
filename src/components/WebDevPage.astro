---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import '../styles/wd-landing-shared.css';

export interface WebDevStep {
  num: string;
  title: string;
  desc: string;
  outcome: string;
}

export interface WebDevCapability {
  icon: string;
  title: string;
  desc: string;
  highlight?: boolean;
}

export interface WebDevInclusionCategory {
  name: string;
  items: string[];
  /** Ruta pública (p. ej. /assets/sections/foo.png) */
  image?: string;
  /** Texto bajo el título (p. ej. card alta del bento) */
  intro?: string;
  /** Cierre o nota bajo la lista */
  footer?: string;
}

export interface WebDevCaseStudyCard {
  industry: string;
  title: string;
  desc: string;
  image: string;
  bullets: string[];
}

/** Sección “Implementation examples” (antes/después + grid), tema claro */
export interface WebDevCaseStudies {
  eyebrow: string;
  headline: string;
  subtext: string;
  featured: {
    beforeLabel: string;
    afterLabel: string;
    beforeImage: string;
    afterImage: string;
    beforeTitle: string;
    beforeDesc: string;
    afterTitle: string;
    afterDesc: string;
    /** Texto breve bajo el bloque comparativo (una línea) */
    comparisonNote: string;
    /** 2–3 tooltips sobre el mockup AFTER */
    highlights: string[];
    /** Mini UI decorativa (capas flotantes) */
    floating: {
      formTitle: string;
      fieldPlaceholder: string;
      formButton: string;
      ctaPill: string;
      analyticsLabel: string;
    };
  };
  secondary: [WebDevCaseStudyCard, WebDevCaseStudyCard];
  footerLine: string;
  footerCta: string;
  footerCtaHref: string;
}

export interface WebDevPageData {
  lang: 'en' | 'es';
  meta: {
    title: string;
    description: string;
    keywords: string;
    hreflangEs: string;
    hreflangEn: string;
  };
  nav: any;
  footer: any;
  hero: {
    badge: string;
    title: string;
    sub: string;
    cta: string;
    ctaHref: string;
    trustBullets: string[];
  };
  painPoints: {
    title: string;
    intro: string;
    items: { icon: string; title: string; desc: string }[];
  };
  capabilities: {
    title: string;
    sub: string;
    items: WebDevCapability[];
  };
  process: {
    title: string;
    sub?: string;
    steps: WebDevStep[];
  };
  inclusions: {
    title: string;
    sub: string;
    categories: WebDevInclusionCategory[];
  };
  idealFor: {
    title: string;
    sub: string;
    items: { label: string; desc: string }[];
  };
  trust: {
    title: string;
    items: { title: string; desc: string }[];
  };
  cta: {
    title: string;
    sub: string;
    button: string;
    href: string;
  };
  /** Ejemplos de implementación (antes/después), tras el CTA principal */
  caseStudies: WebDevCaseStudies;
  related: {
    title: string;
    items: { label: string; href: string }[];
  };
  schemas: object[];
}

const { data } = Astro.props as { data: WebDevPageData };

const inclusionCategories = data.inclusions.categories;
const inclusionsUseBento = inclusionCategories.length >= 3;

const iconPaths: Record<string, string> = {
  clock: 'M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10zm0-2a8 8 0 1 0 0-16 8 8 0 0 0 0 16zm1-8h4v2h-6V7h2v5z',
  zap: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  code: 'M16 18l6-6-6-6M8 6l-6 6 6 6',
  globe: 'M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zm0 0a15.3 15.3 0 0 0 4-10 15.3 15.3 0 0 0-4-10 15.3 15.3 0 0 0-4 10 15.3 15.3 0 0 0 4 10zM2 12h20',
  bot: 'M12 8V4H8M12 8V4h4M12 8v4M9 21H7a2 2 0 0 1-2-2v-4a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2h-2M9 21h6M9 21v-4M15 21v-4M9 17h6',
  chart: 'M18 20V10M12 20V4M6 20v-6',
  check: 'M22 11.08V12a10 10 0 1 1-5.93-9.14M22 4L12 14.01l-3-3',
};
---

<BaseLayout
  lang={data.lang}
  title={data.meta.title}
  description={data.meta.description}
  keywords={data.meta.keywords}
  schemas={data.schemas}
  hreflangEs={data.meta.hreflangEs}
  hreflangEn={data.meta.hreflangEn}
>
  <Nav t={data.nav} lang={data.lang} />

  <main id="main-content">

    <!-- ══════════════════════════════════════════
         1. HERO
    ══════════════════════════════════════════ -->
    <section class="wd-hero">
      <div class="wd-hero-bg" aria-hidden="true"></div>
      <div class="wd-container wd-hero-layout">

        <div class="wd-hero-left">
          <span class="wd-badge">{data.hero.badge}</span>
          <h1 class="wd-h1">{data.hero.title}</h1>
          <p class="wd-hero-sub">{data.hero.sub}</p>

          <a href={data.hero.ctaHref} class="wd-btn-primary">
            {data.hero.cta}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>

          <ul class="wd-trust-bullets" role="list">
            {data.hero.trustBullets.map(b => (
              <li class="wd-trust-bullet">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                {b}
              </li>
            ))}
          </ul>
        </div>

        <div class="wd-hero-right" aria-hidden="true" id="wd-hero-visual">
          <div class="wd-hero-blob"></div>

          <div class="wd-browser-card animate-float-2">
            <div class="wd-browser-chrome">
              <div class="wd-browser-dots">
                <span></span><span></span><span></span>
              </div>
              <div class="wd-browser-url">runtime-lab.com</div>
            </div>
            <div class="wd-browser-body">
              <div class="wd-page-hero-bar"></div>
              <div class="wd-page-content">
                <div class="wd-page-line wd-line-80"></div>
                <div class="wd-page-line wd-line-60"></div>
                <div class="wd-page-line wd-line-40"></div>
                <div class="wd-page-btn"></div>
              </div>
              <div class="wd-page-grid">
                <div class="wd-page-card"></div>
                <div class="wd-page-card"></div>
                <div class="wd-page-card"></div>
              </div>
            </div>
          </div>

          <div class="wd-float-pill wd-pill-speed animate-float-1">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
            &lt;2s load
          </div>

          <div class="wd-float-pill wd-pill-seo animate-float-3">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6L9 17l-5-5"/>
            </svg>
            SEO ✓
          </div>

          <div class="wd-float-pill wd-pill-conv animate-float-4">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 20V10M12 20V4M6 20v-6"/>
            </svg>
            +40% conv.
          </div>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         2. SOCIAL PROOF STRIP
    ══════════════════════════════════════════ -->
    <section class="wd-proof-strip">
      <div class="wd-container">
        <div class="wd-proof-row reveal">
          <div class="wd-proof-item">
            <span class="wd-proof-val">&lt; 2s</span>
            <span class="wd-proof-label">{data.lang === 'es' ? 'Carga promedio' : 'Average load'}</span>
          </div>
          <div class="wd-proof-sep" aria-hidden="true"></div>
          <div class="wd-proof-item">
            <span class="wd-proof-val">90+</span>
            <span class="wd-proof-label">Lighthouse</span>
          </div>
          <div class="wd-proof-sep" aria-hidden="true"></div>
          <div class="wd-proof-item">
            <span class="wd-proof-val">100%</span>
            <span class="wd-proof-label">Mobile-first</span>
          </div>
          <div class="wd-proof-sep" aria-hidden="true"></div>
          <div class="wd-proof-item">
            <span class="wd-proof-val">{data.lang === 'es' ? 'Día 1' : 'Day 1'}</span>
            <span class="wd-proof-label">SEO</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         3. PAIN POINTS — Editorial layout
    ══════════════════════════════════════════ -->
    <section class="wd-section wd-section-dark">
      <div class="wd-container">
        <div class="wd-pain-layout">
          <div class="wd-pain-intro reveal">
            <h2 class="wd-section-title">{data.painPoints.title}</h2>
            <p class="wd-pain-intro-text">{data.painPoints.intro}</p>
          </div>

          <div class="wd-pain-list">
            {data.painPoints.items.map((item, i) => (
              <div class={`wd-pain-item wd-pain-tone-${(i % 4) + 1} reveal reveal-delay-${(i + 1) * 100}`}>
                <div class="wd-pain-icon" aria-hidden="true">
                  <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d={iconPaths[item.icon] ?? iconPaths.check} />
                  </svg>
                </div>
                <div class="wd-pain-content">
                  <h3 class="wd-pain-title">{item.title}</h3>
                  <p class="wd-pain-desc">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         4. CAPABILITIES — Large alternating blocks
    ══════════════════════════════════════════ -->
    <section class="wd-section wd-section-surface">
      <div class="wd-container">
        <div class="wd-section-header reveal">
          <h2 class="wd-section-title">{data.capabilities.title}</h2>
          <p class="wd-section-sub">{data.capabilities.sub}</p>
        </div>

        <!-- Block 1: Conversion Design (left text, right image) -->
        <div class="wd-feature-block reveal">
          <div class="wd-feature-content">
            <div class="wd-feature-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d={iconPaths.chart} />
              </svg>
            </div>
            <h3 class="wd-feature-title">{data.capabilities.items[0].title}</h3>
            <p class="wd-feature-desc">{data.capabilities.items[0].desc}</p>
            <ul class="wd-feature-list">
              <li class="wd-feature-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                {data.lang === 'es' ? 'CTAs estratégicamente ubicados' : 'Strategically placed CTAs'}
              </li>
              <li class="wd-feature-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                {data.lang === 'es' ? 'Flujo de usuario optimizado' : 'Optimized user flow'}
              </li>
              <li class="wd-feature-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                {data.lang === 'es' ? 'Jerarquía visual clara' : 'Clear visual hierarchy'}
              </li>
            </ul>
          </div>
          <div class="wd-feature-visual">
            <div class="wd-feature-frame">
              <div class="wd-feature-placeholder wd-media-conv">
                <div class="wd-media-mock">
                  <div class="wd-media-top"><span></span><span></span><span></span></div>
                  <div class="wd-media-body">
                    <div class="wd-media-chart"></div>
                    <div class="wd-media-cols"><span></span><span></span><span></span></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Block 2: Speed & Performance (right text, left image) -->
        <div class="wd-feature-block wd-feature-reverse reveal reveal-delay-200">
          <div class="wd-feature-visual">
            <div class="wd-feature-frame">
              <div class="wd-feature-placeholder wd-media-speed">
                <div class="wd-media-mock">
                  <div class="wd-media-top"><span></span><span></span><span></span></div>
                  <div class="wd-media-body">
                    <div class="wd-media-line"></div>
                    <div class="wd-media-line wd-media-line-short"></div>
                    <div class="wd-media-meter"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="wd-feature-content">
            <div class="wd-feature-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d={iconPaths.zap} />
              </svg>
            </div>
            <h3 class="wd-feature-title">{data.capabilities.items[1].title}</h3>
            <p class="wd-feature-desc">{data.capabilities.items[1].desc}</p>
            <ul class="wd-feature-list">
              <li class="wd-feature-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                Core Web Vitals {data.lang === 'es' ? 'optimizados' : 'optimized'}
              </li>
              <li class="wd-feature-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                {data.lang === 'es' ? 'Carga menor a 2s' : 'Load under 2s'}
              </li>
              <li class="wd-feature-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                Lighthouse 90+
              </li>
            </ul>
          </div>
        </div>

        <!-- Block 3: Integration (left text, right image) -->
        <div class="wd-feature-block reveal reveal-delay-400">
          <div class="wd-feature-content">
            <div class="wd-feature-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d={iconPaths.bot} />
              </svg>
            </div>
            <h3 class="wd-feature-title">{data.capabilities.items[3].title}</h3>
            <p class="wd-feature-desc">{data.capabilities.items[3].desc}</p>
            <ul class="wd-feature-list">
              <li class="wd-feature-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                {data.lang === 'es' ? 'Conexión con CRM' : 'CRM connection'}
              </li>
              <li class="wd-feature-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                {data.lang === 'es' ? 'Agentes de IA integrados' : 'Integrated AI agents'}
              </li>
              <li class="wd-feature-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                {data.lang === 'es' ? 'Seguimiento automatizado' : 'Automated follow-up'}
              </li>
            </ul>
          </div>
          <div class="wd-feature-visual">
            <div class="wd-feature-frame">
              <div class="wd-feature-placeholder wd-media-flow">
                <div class="wd-media-mock">
                  <div class="wd-media-flow-nodes"><span></span><span></span><span></span><span></span></div>
                  <div class="wd-media-flow-line"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         4.5. VISUAL SHOWCASE — Large image block
    ══════════════════════════════════════════ -->
    <section class="wd-visual-section">
      <div class="wd-visual-glow" aria-hidden="true"></div>
      <div class="wd-container">
        <div class="wd-visual-layout">
          <div class="wd-visual-content reveal">
            <h2 class="wd-visual-title">{data.lang === 'es' ? 'Diseño que convierte' : 'Design that converts'}</h2>
            <p class="wd-visual-desc">
              {data.lang === 'es'
                ? 'Cada elemento está diseñado para guiar al visitante hacia la acción. No hacemos sitios bonitos que no venden.'
                : 'Every element is designed to guide visitors toward action. We don\'t make pretty sites that don\'t sell.'}
            </p>
            <ul class="wd-visual-list" role="list">
              <li class="wd-visual-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                {data.lang === 'es' ? 'Jerarquía visual clara' : 'Clear visual hierarchy'}
              </li>
              <li class="wd-visual-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                {data.lang === 'es' ? 'CTAs estratégicos' : 'Strategic CTAs'}
              </li>
              <li class="wd-visual-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                {data.lang === 'es' ? 'Flujo sin fricción' : 'Frictionless flow'}
              </li>
            </ul>
          </div>
          <div class="wd-visual-image reveal">
            <div class="wd-visual-frame">
              <div class="wd-visual-placeholder wd-visual-mock-a">
                <div class="wd-media-mock">
                  <div class="wd-media-top"><span></span><span></span><span></span></div>
                  <div class="wd-media-body">
                    <div class="wd-media-chart"></div>
                    <div class="wd-media-cols"><span></span><span></span><span></span></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         5. PROCESS — Sticky stack cards
    ══════════════════════════════════════════ -->
    <section class="wd-process-section">
      <div class="wd-container">
        <div class="wd-section-header reveal">
          <h2 class="wd-section-title">{data.process.title}</h2>
          {data.process.sub && <p class="wd-section-sub">{data.process.sub}</p>}
        </div>
      </div>

      <div class="wd-stack-wrapper" role="list">

        <!-- CARD 01 — Discovery: light/white -->
        <article class="wd-stack-card wd-card-light" style="--card-z:1" role="listitem">
          <div class="wd-stack-inner">
            <div class="wd-stack-visual" aria-hidden="true">
              <div class="wd-sim-window wd-sim-light">
                <div class="wd-sim-chrome"><span class="wd-dot-r"></span><span class="wd-dot-y"></span><span class="wd-dot-g"></span><span class="wd-sim-url">brief.runtime-lab.com</span></div>
                <div class="wd-sim-content">
                  <div class="wd-brief-header-row">
                    <div class="wd-brief-logo-block"><span class="wd-logo-sq"></span><span class="wd-logo-txt"></span></div>
                    <span class="wd-brief-badge">Strategy brief</span>
                  </div>
                  <div class="wd-brief-section-title"></div>
                  <div class="wd-brief-form">
                    <div class="wd-form-group"><div class="wd-form-label"></div><div class="wd-form-input"></div></div>
                    <div class="wd-form-group"><div class="wd-form-label"></div><div class="wd-form-input"></div></div>
                    <div class="wd-form-checks">
                      <div class="wd-form-check wd-check-on"><span class="wd-check-box"></span><span class="wd-check-text"></span></div>
                      <div class="wd-form-check wd-check-on"><span class="wd-check-box"></span><span class="wd-check-text"></span></div>
                      <div class="wd-form-check"><span class="wd-check-box"></span><span class="wd-check-text"></span></div>
                    </div>
                    <div class="wd-form-cta"></div>
                  </div>
                </div>
              </div>
            </div>
            <div class="wd-stack-content">
              <span class="wd-stack-num wd-num-light" aria-hidden="true">{data.process.steps[0].num}</span>
              <h3 class="wd-stack-title wd-title-dark">{data.process.steps[0].title}</h3>
              <p class="wd-stack-desc wd-desc-dark">{data.process.steps[0].desc}</p>
              <div class="wd-stack-outcome wd-outcome-dark">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
                {data.process.steps[0].outcome}
              </div>
            </div>
          </div>
        </article>

        <!-- CARD 02 — Architecture: blue -->
        <article class="wd-stack-card wd-card-blue" style="--card-z:2" role="listitem">
          <div class="wd-stack-inner">
            <div class="wd-stack-visual" aria-hidden="true">
              <div class="wd-sim-sitemap">
                <div class="wd-sitemap-node wd-sn-root"><span>Home</span></div>
                <div class="wd-sitemap-children">
                  <div class="wd-sitemap-branch">
