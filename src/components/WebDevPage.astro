/* ══ CASE STUDIES — Light showcase (after main CTA) ══ */
.wd-cs {
  position: relative;
  padding: 0;
  overflow: hidden;
  background: linear-gradient(180deg, #eef2f7 0%, #f8fafc 45%, #f1f5f9 100%);
  color: #0f172a;
  border-top: 1px solid rgba(15, 23, 42, 0.06);
  border-bottom: 1px solid rgba(15, 23, 42, 0.06);
}
.wd-cs-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 0%, rgba(37, 99, 235, 0.07) 0%, transparent 55%),
    radial-gradient(ellipse 60% 50% at 100% 40%, rgba(99, 102, 241, 0.05) 0%, transparent 50%);
  pointer-events: none;
  will-change: transform;
}
.wd-cs-glow {
  position: absolute;
  width: min(900px, 90vw);
  height: 420px;
  left: 50%;
  top: 28%;
  transform: translateX(-50%);
  background: radial-gradient(ellipse at center, rgba(37, 99, 235, 0.12) 0%, transparent 70%);
  filter: blur(60px);
  pointer-events: none;
  opacity: 0.9;
}
.wd-cs-inner {
  position: relative;
  z-index: 1;
  max-width: 1280px;
}
.wd-cs-header {
  max-width: 700px;
  margin: 0 auto;
  padding: 140px 1.5rem 48px;
  text-align: center;
}
@media (max-width: 640px) {
  .wd-cs-header {
    padding-top: 96px;
    padding-bottom: 40px;
  }
}
.wd-cs-eyebrow {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: #64748b;
  margin: 0 0 14px;
}
.wd-cs-title {
  font-size: clamp(1.85rem, 4vw, 2.5rem);
  font-weight: 800;
  letter-spacing: -0.035em;
  line-height: 1.15;
  color: #0f172a;
  margin: 0 0 16px;
}
.wd-cs-sub {
  font-size: 1.0625rem;
  line-height: 1.65;
  color: #64748b;
  margin: 0;
  font-weight: 400;
}
.wd-cs-featured {
  padding: 0 1.5rem 140px;
}
.wd-cs-compare {
  display: grid;
  grid-template-columns: minmax(0, 38fr) minmax(0, 62fr);
  gap: clamp(20px, 3.5vw, 40px);
  max-width: 1280px;
  margin: 0 auto;
  align-items: start;
}
@media (max-width: 960px) {
  .wd-cs-compare {
    grid-template-columns: 1fr;
    gap: 40px;
  }
}
.wd-cs-ba-before,
.wd-cs-ba-after {
  min-width: 0;
}
.wd-cs-ba-before {
  opacity: 0;
  transform: translateY(18px);
  transition:
    opacity 0.65s ease-out,
    transform 0.65s ease-out;
}
.wd-cs-compare--in .wd-cs-ba-before {
  opacity: 1;
  transform: translateY(0);
}
.wd-cs-ba-after {
  opacity: 0;
  transform: scale(0.96);
  transform-origin: center top;
  transition:
    opacity 0.72s cubic-bezier(0.2, 0.85, 0.25, 1) 0.16s,
    transform 0.72s cubic-bezier(0.2, 0.85, 0.25, 1) 0.16s;
}
.wd-cs-compare--in .wd-cs-ba-after {
  opacity: 1;
  transform: scale(1);
}
.wd-cs-after-stage {
  position: relative;
  overflow: visible;
  padding: 12px 0 28px;
}
.wd-cs-after-aura {
  position: absolute;
  width: 120%;
  height: 90%;
  left: -8%;
  top: 4%;
  background:
    radial-gradient(ellipse 70% 70% at 60% 40%, rgba(99, 102, 241, 0.18) 0%, transparent 55%),
    radial-gradient(ellipse 60% 60% at 30% 60%, rgba(37, 99, 235, 0.2) 0%, transparent 50%);
  filter: blur(36px);
  pointer-events: none;
  z-index: 0;
  will-change: transform;
  transition: transform 0.15s linear;
}
.wd-cs-frame {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  height: clamp(320px, 42vw, 440px);
  width: 100%;
  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.5s ease;
}
.wd-cs-frame--before {
  box-shadow: 0 2px 8px rgba(15, 23, 42, 0.06);
}
.wd-cs-frame--before:hover {
  transform: none;
}
.wd-cs-img-el--before {
  opacity: 0.68;
}
.wd-cs-img-el--before img {
  filter: blur(2px) saturate(0.62) contrast(0.88);
  transform: scale(1.05);
}
.wd-cs-img-overlay--before {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.38);
  pointer-events: none;
  z-index: 1;
}
.wd-cs-img-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
}
.wd-cs-noise {
  position: absolute;
  inset: 0;
  opacity: 0.28;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  mix-blend-mode: overlay;
  pointer-events: none;
  z-index: 2;
}
.wd-cs-img-el {
  width: 100%;
  height: 100%;
  position: relative;
  background: #e2e8f0;
}
.wd-cs-img-el img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}
.wd-cs-frame--after {
  z-index: 2;
  transform: translateY(-6px);
  box-shadow:
    0 4px 6px -1px rgba(15, 23, 42, 0.06),
    0 28px 56px -12px rgba(37, 99, 235, 0.28),
    0 48px 80px -24px rgba(15, 23, 42, 0.12);
}
.wd-cs-ba-after:hover .wd-cs-frame--after {
  transform: translateY(-6px) scale(1.02);
  box-shadow:
    0 8px 16px -2px rgba(37, 99, 235, 0.2),
    0 36px 64px -16px rgba(37, 99, 235, 0.35),
    0 56px 100px -28px rgba(15, 23, 42, 0.14);
}
.wd-cs-after-glow {
  position: absolute;
  inset: -25%;
  background: radial-gradient(circle at 50% 28%, rgba(37, 99, 235, 0.28) 0%, transparent 52%);
  pointer-events: none;
  z-index: 0;
}
.wd-cs-frame--after .wd-cs-img-el {
  position: relative;
  z-index: 1;
}
.wd-cs-tag {
  position: absolute;
  top: 14px;
  left: 14px;
  z-index: 6;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #64748b;
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(15, 23, 42, 0.08);
  padding: 6px 10px;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(15, 23, 42, 0.06);
}
.wd-cs-tag--after {
  color: #fff;
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  border-color: rgba(255, 255, 255, 0.25);
  box-shadow: 0 4px 20px rgba(37, 99, 235, 0.4);
}
.wd-cs-pins {
  position: absolute;
  inset: 0;
  z-index: 5;
  pointer-events: none;
  will-change: transform;
  transition: transform 0.15s linear;
}
.wd-cs-pin {
  position: absolute;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  max-width: 168px;
  padding: 8px 11px;
  font-size: 11px;
  font-weight: 600;
  color: #0f172a;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(37, 99, 235, 0.22);
  border-radius: 10px;
  box-shadow:
    0 6px 20px rgba(15, 23, 42, 0.1),
    0 0 0 1px rgba(255, 255, 255, 0.75) inset;
  opacity: 0;
  transform: translateY(10px) scale(0.96);
}
.wd-cs-compare--in .wd-cs-pin {
  animation: wd-cs-pin-in 0.55s ease-out forwards;
}
.wd-cs-pin:nth-child(1) {
  top: 9%;
  left: 54%;
  animation-delay: 0.45s;
}
.wd-cs-pin:nth-child(2) {
  top: 36%;
  left: 6%;
  animation-delay: 0.58s;
}
.wd-cs-pin:nth-child(3) {
  bottom: 14%;
  right: 5%;
  animation-delay: 0.7s;
}
@media (max-width: 640px) {
  .wd-cs-pin {
    max-width: 132px;
    font-size: 10px;
    padding: 6px 8px;
  }
  .wd-cs-pin:nth-child(1) {
    top: 6%;
    left: 40%;
  }
  .wd-cs-pin:nth-child(2) {
    top: 34%;
    left: 2%;
  }
}
.wd-cs-pin-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #22c55e;
  box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.25);
  flex-shrink: 0;
}
@keyframes wd-cs-pin-in {
  from {
    opacity: 0;
    transform: translateY(10px) scale(0.96);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
.wd-cs-float {
  position: absolute;
  z-index: 6;
  pointer-events: none;
  background: rgba(255, 255, 255, 0.88);
