---
export interface Props {
  t: {
    title: string;
    subtitle: string;
    blocks: Array<{
      icon?: string;
      title: string;
      items: string[];
      result: string;
    }>;
  };
}
const { t } = Astro.props;

const iconMap: Record<string, string> = {
  globe: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  bot: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" y1="16" x2="8" y2="16"/><line x1="16" y1="16" x2="16" y2="16"/></svg>`,
  zap: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  inbox: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>`,
  code: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
};
---

<section
  id="capabilities"
  class="cap-section"
  aria-labelledby="capabilities-heading"
>
  <div class="cap-glow" aria-hidden="true"></div>

  <div class="cap-container">

    <div class="cap-header reveal">
      <h2
        id="capabilities-heading"
        class="cap-title"
      >
        {t.title}
      </h2>
      <p class="cap-subtitle">
        {t.subtitle}
      </p>
    </div>

    <div class="cap-grid">
      {t.blocks.map((block, i) => (
        <div class={`cap-card reveal reveal-delay-${(i + 1) * 100}`}>
          <div class="cap-card-inner">
            <div class="cap-icon-wrap">
              <div class="cap-icon" set:html={iconMap[block.icon || 'globe'] || iconMap.globe} />
            </div>
            <div class="cap-num" aria-hidden="true">0{i + 1}</div>
            <h3 class="cap-card-title">{block.title}</h3>
            <ul class="cap-items" role="list">
              {block.items.map((item) => (
                <li class="cap-item">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                    <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
            <div class="cap-result">{block.result}</div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .cap-section {
    position: relative;
    background-color: #080C14;
    padding: clamp(5rem, 10vw, 8rem) 0;
    border-top: 1px solid rgba(30, 41, 59, 0.5);
    overflow: hidden;
  }

  .cap-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 60% 40% at 30% 20%, rgba(37, 99, 235, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 80% 80%, rgba(124, 58, 237, 0.06) 0%, transparent 60%);
  }

  .cap-container {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 64px);
  }

  .cap-header {
    text-align: center;
    margin-bottom: clamp(3rem, 6vw, 4.5rem);
  }

  .cap-title {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 900;
    color: #F8FAFC;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .cap-subtitle {
    font-size: clamp(0.95rem, 1.6vw, 1.1rem);
    color: #64748B;
    line-height: 1.6;
    max-width: 640px;
    margin: 0 auto;
  }

  /* Desktop: 6-column grid so rows of 3 and 2 both work cleanly */
  .cap-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.25rem;
  }

  /* Row 1: 3 cards each spanning 2 of 6 columns */
  .cap-card:nth-child(1),
  .cap-card:nth-child(2),
  .cap-card:nth-child(3) {
    grid-column: span 2;
  }

  /* Row 2: 2 cards, each spanning 3 of 6 columns, naturally centered */
  .cap-card:nth-child(4) {
    grid-column: span 3;
  }
  .cap-card:nth-child(5) {
    grid-column: span 3;
  }

  @media (max-width: 900px) {
    .cap-grid {
      grid-template-columns: 1fr 1fr;
    }
    .cap-card:nth-child(1),
    .cap-card:nth-child(2),
    .cap-card:nth-child(3),
    .cap-card:nth-child(4),
    .cap-card:nth-child(5) {
      grid-column: span 1;
    }
  }

  @media (max-width: 580px) {
    .cap-grid {
      grid-template-columns: 1fr;
    }
  }

  .cap-card {
    position: relative;
    border-radius: 16px;
    background: rgba(16, 21, 28, 0.7);
    border: 1px solid rgba(30, 41, 59, 0.6);
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    backdrop-filter: blur(8px);
  }

  .cap-card:hover {
    border-color: rgba(37, 99, 235, 0.4);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(37, 99, 235, 0.1), 0 0 0 1px rgba(37, 99, 235, 0.08);
  }

  .cap-card-inner {
    padding: clamp(1.5rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .cap-icon-wrap {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(37, 99, 235, 0.1);
    border: 1px solid rgba(37, 99, 235, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    color: #3B82F6;
    transition: background 0.2s, border-color 0.2s;
  }

  .cap-card:hover .cap-icon-wrap {
    background: rgba(37, 99, 235, 0.18);
    border-color: rgba(59, 130, 246, 0.4);
  }

  .cap-num {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    color: rgba(37, 99, 235, 0.25);
  }

  .cap-card-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #F8FAFC;
    letter-spacing: -0.015em;
    margin: 0 0 1rem;
  }

  .cap-items {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .cap-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: #94A3B8;
    line-height: 1.5;
  }

  .cap-item svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: #3B82F6;
  }

  .cap-result {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #3B82F6;
    line-height: 1.4;
    padding-top: 1rem;
    border-top: 1px solid rgba(30, 41, 59, 0.5);
    margin-top: auto;
  }
</style>
