---
export interface Props {
  t: {
    tagline: string;
    nav: { systems: string; howItWorks: string; caseStudies: string; contact: string };
    contact: { email: string; phone: string; address: string };
    legal: { privacy: string; terms: string; copyright: string };
  };
  nav: { logo: string };
  lang?: 'en' | 'es';
}
const { t, nav, lang = 'en' } = Astro.props;
const privacyHref = lang === 'es' ? '/es/privacy' : '/privacy';
const termsHref   = lang === 'es' ? '/es/terms'   : '/terms';
const currentYear = new Date().getFullYear();
---

<footer
  class="footer-professional"
  role="contentinfo"
  aria-label="Site footer"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Main footer: 3 columns -->
    <div class="footer-grid">
      <!-- Left: Logo + tagline -->
      <div class="footer-brand">
        <a href="/" class="footer-logo group" aria-label="RuntimeLab home">
          <img
            src="/assets/logo.png"
            width="160"
            alt={nav.logo}
            class="footer-logo-img"
          />
        </a>
        <p class="footer-tagline">{t.tagline}</p>
      </div>

      <!-- Middle: Navigation -->
      <nav class="footer-nav" aria-label="Footer navigation">
        <div class="footer-nav-label">Navigation</div>
        <ul class="footer-nav-list" role="list">
          <li><a href="#capabilities">{t.nav.systems}</a></li>
          <li><a href="#structure">{t.nav.howItWorks}</a></li>
          <li><a href="#engineering">{t.nav.caseStudies}</a></li>
          <li><a href="#decision">{t.nav.contact}</a></li>
        </ul>
      </nav>

      <!-- Right: Contact -->
      <div class="footer-contact">
        <div class="footer-nav-label">Contact</div>
        <ul class="footer-contact-list" role="list">
          <li>
            <a href={`mailto:${t.contact.email}`} class="footer-contact-link">
              <svg class="footer-contact-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
              {t.contact.email}
            </a>
          </li>
          <li>
            <a href={`tel:${t.contact.phone.replace(/\s/g, '')}`} class="footer-contact-link">
              <svg class="footer-contact-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              {t.contact.phone}
            </a>
          </li>
          <li class="footer-address">
            <span class="footer-contact-icon-wrap" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </span>
            <span>{t.contact.address}</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom row: Legal -->
    <div class="footer-bottom">
      <div class="footer-legal">
        <a href={privacyHref} class="footer-legal-link">{t.legal.privacy}</a>
        <span class="footer-legal-sep" aria-hidden="true">·</span>
        <a href={termsHref} class="footer-legal-link">{t.legal.terms}</a>
      </div>
      <p class="footer-copyright">{t.legal.copyright.replace('{year}', String(currentYear))}</p>
    </div>

  </div>
</footer>

<style>
  .footer-professional {
    background-color: #050810;
    border-top: 1px solid #1E293B;
    padding: 3rem 0 2rem;
    margin-top: 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem 3rem;
    padding-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.2fr 1fr 1.2fr;
    }
  }

  .footer-brand {
    max-width: 280px;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .footer-logo-img {
    display: block;
    height: auto;
    max-width: 170px;
  }

  .footer-tagline {
    font-size: 0.8125rem;
    color: #64748B;
    line-height: 1.5;
  }

  .footer-nav-label,
  .footer-contact .footer-nav-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #64748B;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .footer-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-nav-list li {
    margin-bottom: 0.5rem;
  }

  .footer-nav-list a {
    font-size: 0.875rem;
    color: #94A3B8;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-nav-list a:hover {
    color: #F8FAFC;
  }

  .footer-contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-contact-list li {
    margin-bottom: 0.625rem;
  }

  .footer-contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #94A3B8;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-contact-link:hover {
    color: #F8FAFC;
  }

  .footer-contact-icon {
    flex-shrink: 0;
    color: #64748B;
  }

  .footer-contact-link:hover .footer-contact-icon {
    color: #2563EB;
  }

  .footer-address {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #94A3B8;
    line-height: 1.5;
  }

  .footer-contact-icon-wrap {
    flex-shrink: 0;
    color: #64748B;
    margin-top: 2px;
  }

  .footer-bottom {
    padding-top: 1.5rem;
    border-top: 1px solid #1E293B;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-legal-link {
    font-size: 0.75rem;
    color: #64748B;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-legal-link:hover {
    color: #94A3B8;
  }

  .footer-legal-sep {
    color: #334155;
    font-size: 0.75rem;
  }

  .footer-copyright {
    font-size: 0.75rem;
    color: #64748B;
    margin: 0;
  }
</style>
